{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/vault/refs/heads/main/json-schema/vault-sys-auth-method-config-schema.json",
  "title": "AuthMethodConfig",
  "description": "AuthMethodConfig schema from HashiCorp Vault API",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "description": "Auth method type.",
      "example": "approle"
    },
    "description": {
      "type": "string",
      "description": "Description of the auth method.",
      "example": "AppRole auth method"
    },
    "accessor": {
      "type": "string",
      "description": "Accessor for the auth method.",
      "example": "auth_approle_abc123"
    }
  }
}